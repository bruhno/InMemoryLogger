<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.9" />
  </ItemGroup>

  <PropertyGroup>
	<PackageId>Brukhno.InMemoryLogger</PackageId>
  	<TargetFramework>net9.0</TargetFramework>
  	<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  	<Version>1.0.0</Version>
  	<Authors>gennady.brukhno</Authors>  	  	
  	<Description>Lightweight in-memory logger for .NET applications.</Description>
  	<PackageLicenseExpression>MIT</PackageLicenseExpression>
  	<RepositoryUrl>https://github.com/bruhno/InMemoryLogger</RepositoryUrl>
  	<RepositoryType>git</RepositoryType>
  	<PackageTags>logging;memory;dotnet;diagnostics</PackageTags>
  </PropertyGroup>
</Project>
